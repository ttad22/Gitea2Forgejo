{
  "name": "sqlite-gitea",
  "host": "sqlite-git.example.org",
  "gitea_version": "1.22.4",
  "postgres_version": "n/a",
  "app_ini_path": "/etc/gitea/app.ini",
  "data_root": "/var/lib/gitea",
  "service": {
    "install_mode": "systemd-binary",
    "reverse_proxy": "caddy",
    "database": "sqlite",
    "app_service_name": "gitea",
    "ssh_mode": "embedded-ssh"
  },
  "resources": {
    "root_free_gb": 22.0,
    "gitea_total_mb": 1536.0,
    "repositories_mb": 1024.0,
    "attachments_mb": 180.0,
    "lfs_mb": 0.0,
    "packages_mb": 0.0
  },
  "features": {
    "repositories": 21,
    "users": 12,
    "org_memberships": 9,
    "lfs_objects": 0,
    "action_runs": 0,
    "action_runners": 0,
    "packages": 0
  },
  "notes": [
    "domain=git.sqlite.example.net",
    "root_url=https://git.sqlite.example.net/",
    "sqlite backend requires explicit export/restore strategy"
  ]
}
