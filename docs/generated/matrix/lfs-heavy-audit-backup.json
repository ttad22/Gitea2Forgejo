{
  "deployment_name": "lfs-gitea",
  "backup_root_hint": "/var/backups/gitea-forgejo-migrator",
  "vm_snapshot_required": true,
  "items": [
    {
      "label": "vm_snapshot",
      "kind": "hypervisor_snapshot",
      "path": null,
      "command": "Create hypervisor snapshot before service replacement.",
      "required": true
    },
    {
      "label": "postgres_dump",
      "kind": "database_dump",
      "path": null,
      "command": "sudo -u postgres pg_dump -Fc gitea > gitea.pre-forgejo.dump",
      "required": true
    },
    {
      "label": "app_ini",
      "kind": "file_archive",
      "path": "/etc/gitea/app.ini",
      "command": null,
      "required": true
    },
    {
      "label": "custom",
      "kind": "directory_archive",
      "path": "/var/lib/gitea/custom",
      "command": null,
      "required": true
    },
    {
      "label": "data",
      "kind": "directory_archive",
      "path": "/var/lib/gitea/data",
      "command": null,
      "required": true
    },
    {
      "label": "lfs",
      "kind": "directory_archive",
      "path": "/var/lib/gitea/lfs",
      "command": null,
      "required": true
    },
    {
      "label": "log",
      "kind": "directory_archive",
      "path": "/var/lib/gitea/log",
      "command": null,
      "required": false
    }
  ]
}
